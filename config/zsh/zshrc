autoload -Uz compinit && compinit

# Plugins
source ~/.nix-profile/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

source ~/.zshenv_local
eval "$(direnv hook zsh)"

# PATH
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/go/bin:$PATH"
export PATH="/Applications/Sublime Text.app/Contents/SharedSupport/bin:$PATH"
export PATH="/Applications/RubyMine.app/Contents/MacOS:$PATH"

# mise（他の PATH 変更より後に実行することで mise が優先される）
eval "$(mise activate zsh)"

# starship は Nix 環境ロード後に初期化（初回プロンプト後に適用）
_init_starship() {
  if command -v starship &>/dev/null; then
    eval "$(starship init zsh)"
    precmd_functions=("${(@)precmd_functions:#_init_starship}")
  fi
}
precmd_functions+=(_init_starship)
